@startuml
scale 4
hide circle
skinparam classAttributeIconSize 0

class Command {
    --
    + execute(inventory: Inventory, recipes: RecipeBook): void
}

class RecommendByIngredientCommand {
    - ingredientName: String
    --
}

class RecommendByInventoryCommand {
    --
}

class RecommendByMissingCommand {
    - maxMissing: int
    --
}

class Inventory {
    --
}

class RecipeBook {
    --
}

class Ingredient {
    - name: String
    - quantity: double
    - unit: String
    --
}

class Recipe {
    - name: String
    --
}

together {
    class RecommendByIngredientCommand
    class RecommendByInventoryCommand
    class RecommendByMissingCommand
}

' Guide layout: data stores below outer subclasses to avoid crossings
RecommendByIngredientCommand -[hidden]-> Inventory
RecommendByMissingCommand -[hidden]-> RecipeBook

' Inheritance
RecommendByIngredientCommand --|> Command
RecommendByInventoryCommand --|> Command
RecommendByMissingCommand --|> Command

' All commands operate on Inventory and RecipeBook via execute()
Command ..> Inventory
Command ..> RecipeBook

' Inventory owns Ingredients by value; Recipe references shared Ingredient instances
Inventory "1" o-- "*" Ingredient
RecipeBook "1" *-- "*" Recipe
Recipe "*" o-- "*" Ingredient

@enduml